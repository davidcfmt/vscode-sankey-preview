{
  "name": "sankey-markdown-preview",
  "displayName": "Sankey Markdown Preview",
  "description": "Write and preview text-based Sankey diagrams inside Markdown and .sankey files with multi-layer support and professional styling.",
  "version": "2.1.0",
  "publisher": "DavidCampbell",
  "author": {
    "name": "David Campbell",
    "email": "david.campbell11@outlook.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/davidcfmt/vscode-sankey-preview.git"
  },
  "bugs": {
    "url": "https://github.com/davidcfmt/vscode-sankey-preview/issues"
  },
  "homepage": "https://github.com/davidcfmt/vscode-sankey-preview#readme",
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Other",
    "Visualization",
    "Programming Languages"
  ],
  "keywords": [
    "sankey",
    "diagram",
    "markdown",
    "visualization",
    "flow",
    "chart",
    "d3",
    "preview"
  ],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onLanguage:sankey",
    "onLanguage:markdown"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sankey",
        "aliases": [
          "Sankey"
        ],
        "extensions": [
          ".sankey"
        ]
      }
    ],
    "grammars": [
      {
        "language": "sankey",
        "scopeName": "source.sankey",
        "path": "./syntaxes/sankey.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "sankey",
        "path": "./snippets/sankey.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "sankeyPreview.show",
        "title": "Open Sankey Preview"
      },
      {
        "command": "sankeyPreview.exportSvg",
        "title": "Sankey: Export SVG"
      },
      {
        "command": "sankeyPreview.exportPng",
        "title": "Sankey: Export PNG"
      },
      {
        "command": "sankeyPreview.copyMermaid",
        "title": "Sankey: Copy as Mermaid Sankey"
      }
    ],
    "keybindings": [
      {
        "command": "sankeyPreview.show",
        "key": "ctrl+shift+p",
        "when": "resourceExtname == .sankey"
      }
    ],
    "markdown.previewScripts": [
      "./media/preview.js"
    ]
  },
  "configuration": {
    "title": "Sankey Preview",
    "properties": {
      "sankeyPreview.maxInputSize": {
        "type": "number",
        "default": 100000,
        "description": "Maximum input size in bytes (100KB default)"
      },
      "sankeyPreview.maxNodes": {
        "type": "number",
        "default": 1000,
        "description": "Maximum number of nodes allowed"
      },
      "sankeyPreview.maxLinks": {
        "type": "number",
        "default": 5000,
        "description": "Maximum number of links allowed"
      },
      "sankeyPreview.autoRefresh": {
        "type": "boolean",
        "default": true,
        "description": "Automatically refresh preview on save"
      }
    }
  },
  "scripts": {
    "build": "esbuild src/previewRenderer.js --bundle --format=iife --target=es2020 --outfile=media/preview.js",
    "lint": "eslint src --ext .js",
    "test": "node tests/parser.test.js && node tests/preview-source.test.js",
    "vscode:prepublish": "npm run build",
    "package": "npm run build && vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.91.0",
    "@vscode/vsce": "^3.9.2",
    "d3-sankey": "^0.12.3",
    "esbuild": "^0.28.1",
    "eslint": "^8.57.0"
  }
}
